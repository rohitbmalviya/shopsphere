# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite for local dev. Swap to postgres:// for production.
DATABASE_URL="file:./prisma/dev.db"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: `openssl rand -base64 32`
AUTH_SECRET="changeme-replace-with-openssl-rand-base64-32"
